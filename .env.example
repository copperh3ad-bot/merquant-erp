# Copy this file to .env and fill in your values.
# Production values (for Netlify) are documented in tasks/NETLIFY_ENV.md.

# === Required ===
# Supabase project URL (e.g. https://jcbxmpgjirxqszodotmx.supabase.co)
VITE_SUPABASE_URL=your_supabase_project_url
# Supabase anon (publishable) key — safe to expose in the browser bundle
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# === Phase 4 — agentic AI Assistant feature flag ===
# Set to "true" to route AIAssistant.jsx through ai-assistant-v2 (multi-tool
# loop with read/write tool gating). Default unset/false uses the legacy
# ai-proxy single-shot path. Toggle off to roll back without redeploying.
# VITE_USE_AI_V2=true

# === Phase 7 — Email crawler Gmail OAuth ===
# Google OAuth client ID for the Gmail-connect flow inside
# EmailCrawlerAgentPanel.jsx. The corresponding client secret lives in
# Supabase edge function secrets (GOOGLE_CLIENT_SECRET), never in the
# browser bundle.
# VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id.apps.googleusercontent.com
